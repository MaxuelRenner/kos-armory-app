{
  "expo": {
    "name": "КОС Арсенал",
    "slug": "kos-armory-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kos-armory",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A0B0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "bg.kosarmory.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1114"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "package": "bg.kosarmory.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0A0B0D"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложението се нуждае от достъп до галерията, за да добавите снимка на оръжието.",
          "cameraPermission": "Приложението се нуждае от достъп до камерата, за да снимате оръжието."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a581a11-22c1-4398-ab62-168249430e25"
      }
    },
    "owner": "maxuelrenner"
  }
}